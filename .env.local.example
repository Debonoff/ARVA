# ─────────────────────────────────────────────────────────────
# Arva — переменные окружения
# Скопируйте этот файл в .env.local и подставьте свои значения.
# В Vercel те же переменные добавьте в Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Только для сервера (движок роста / cron). НЕ добавляйте префикс NEXT_PUBLIC_!
# Supabase → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Секрет для защиты ежедневного cron-эндпоинта /api/cron/growth.
# Придумайте любую длинную строку. В Vercel добавьте её же как CRON_SECRET.
CRON_SECRET=change-me-to-a-long-random-string
